{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "http://*" }, { "url": "http://*/*" }]
    }
  ]
}
